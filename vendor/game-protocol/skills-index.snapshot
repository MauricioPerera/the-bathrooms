cept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1150","metadata":{"content":"mismo artefacto.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1151","metadata":{"content":"mismo artefacto.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1152","metadata":{"content":"ismo artefacto.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1153","metadata":{"content":"smo artefacto.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1154","metadata":{"content":"mo artefacto.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1155","metadata":{"content":"o artefacto.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1156","metadata":{"content":"artefacto.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1157","metadata":{"content":"artefacto.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1158","metadata":{"content":"rtefacto.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1159","metadata":{"content":"tefacto.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#116","metadata":{"content":"n del protocolo sigue en `0.1`.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1160","metadata":{"content":"efacto.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1161","metadata":{"content":"facto.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1162","metadata":{"content":"acto.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1163","metadata":{"content":"cto.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1164","metadata":{"content":"to.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1165","metadata":{"content":"o.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1166","metadata":{"content":".","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1167","metadata":{"content":"### Added — fricciones de autoría del stress-test (perfil monster-rpg)\n- **Forma compacta hex para el arte 4bpp** (`tileArt` y `sprites`): además de la matriz\n  de números, se acepta un array de strings hex — 1 carácter = 1 celda `0..15`\n  (`tileArt`: 8 strings de 8; `sprites`: 16 de 16). Las líneas de arte encogen ~1,8×\n  (medido en `kaiju-island`: 13.560 → 12.477 bytes). La forma compacta\n  se **decodifica al compilar**: mismo `window.GAME` byte a byte que la forma matriz\n  (verificado con `kaiju-island`, convertido a hex con generado idéntico).","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1168","metadata":{"content":"sland`, convertido a hex con generado idéntico). Helper\n  isomorfo `decodeArtRows` en `tools/profile-helpers.js` (opt-in vía\n  `ruleTileArt(..., {allowHex})`, disponible para otros perfiles).\n- **Secciones canónicas ampliadas**: `Sprites`, `Moves`, `Trainers`, `Encounters` y\n  `Sfx` son secciones `##` de primera clase (antes había que anidarlas como `###` o\n  aceptar warnings de `section-order`). Aditivo: los docs existentes usan un\n  subconjunto cuyo orden relativo se preserva.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1169","metadata":{"content":"n\n  subconjunto cuyo orden relativo se preserva.\n\n### Fixed\n- Eliminado el warn por comas en `dialogue` de NPCs (`overworld-ref`): era un **falso\n  positivo** — una coma que sobrevive al parseo proviene siempre de un string entre\n  comillas (uso correcto); la coma sin comillas rompe el parseo de flujo con\n  `parse-error` claro antes de llegar a la regla. Guía de los ejemplos actualizada\n  (\"diálogos con comas entre comillas\" en vez de \"sin comas\").\n\n## [2.1.0] — 2026-07-07","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#117","metadata":{"content":"del protocolo sigue en `0.1`.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1170","metadata":{"content":"vez de \"sin comas\").\n\n## [2.1.0] — 2026-07-07\n\nRelease **aditivo** sobre `2.0.1` (bump minor, [SPEC §7.0](./SPEC.md): reglas y ejemplo\nnuevos): el stress-test **Kaiju Island** y el cierre de los 10 huecos de validación que\ndescubrió. La versión del protocolo sigue en `0.1`; sin breaking ni deprecations — los\n`GAME.md` válidos existentes siguen en 0 errores.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1171","metadata":{"content":"AME.md` válidos existentes siguen en 0 errores.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1172","metadata":{"content":"ME.md` válidos existentes siguen en 0 errores.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1173","metadata":{"content":"E.md` válidos existentes siguen en 0 errores.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1174","metadata":{"content":".md` válidos existentes siguen en 0 errores.","okf_concept":"CHANGELOG.md","okf_type":"Documentation","title":"Changelog"}},{"id":"CHANGELOG.md#1175","metadata":{"content":"md` válidos existentes siguen en 0 errores.","okf_concept":"CHANGELOG.md","okf_type":"Documentation"