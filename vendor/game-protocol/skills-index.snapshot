ept":"SPEC.md","okf_type":"Documentation","title":"GAME Protocol — Core Specification"}},{"id":"SPEC.md#261","metadata":{"content":"lint.","okf_concept":"SPEC.md","okf_type":"Documentation","title":"GAME Protocol — Core Specification"}},{"id":"SPEC.md#262","metadata":{"content":"int.","okf_concept":"SPEC.md","okf_type":"Documentation","title":"GAME Protocol — Core Specification"}},{"id":"SPEC.md#263","metadata":{"content":"nt.","okf_concept":"SPEC.md","okf_type":"Documentation","title":"GAME Protocol — Core Specification"}},{"id":"SPEC.md#264","metadata":{"content":"t.","okf_concept":"SPEC.md","okf_type":"Documentation","title":"GAME Protocol — Core Specification"}},{"id":"SPEC.md#265","metadata":{"content":".","okf_concept":"SPEC.md","okf_type":"Documentation","title":"GAME Protocol — Core Specification"}},{"id":"SPEC.md#266","metadata":{"content":"| Field | Type | Required | Constraints |\n|---|---|---|---|\n| `id` | string | yes | kebab-case (`/^[a-z0-9-]+$/`); must match the filename |\n| `specVersion` | string | no | spec version the profile targets (feeds `version-migration`) |\n| `sections` | string[] | no | canonical `##` order for the body |\n| `required` | string[] | no | front-matter tokens `required-fields` demands |\n| `refs` | entry[] | no | each: `{ rule, level, src, target: { collection, allow? }, msg?(), optional? }` — broken-ref family; `msg` omitted → core default message. `src`/`target` accept `arrayField`(`+itemField`) to read/aggregate a nested array field instead of a flat field or the target's own keys — this is how a cross-collection aggregate (e.g.","okf_concept":"SPEC.md","okf_type":"Documentation","title":"GAME Protocol — Core Specification"}},{"id":"SPEC.md#267","metadata":{"content":"— this is how a cross-collection aggregate (e.g.","okf_concept":"SPEC.md","okf_type":"Documentation","title":"GAME Protocol — Core Specification"}},{"id":"SPEC.md#268","metadata":{"content":"this is how a cross-collection aggregate (e.g.","okf_concept":"SPE