{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://game-protocol/schemas/sudoku.schema.json",
  "title": "GAME.md front-matter — perfil sudoku",
  "type": "object",
  "required": [
    "version",
    "name",
    "profile"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "profile": {
      "const": "sudoku"
    },
    "platform": {
      "type": "object"
    },
    "palettesCount": {
      "type": "integer",
      "minimum": 0
    },
    "puzzles": {
      "type": "object"
    },
    "player": {
      "type": "object"
    },
    "balance": {
      "type": "object"
    },
    "text": {
      "type": "object"
    }
  },
  "additionalProperties": true,
  "x-sections": [
    "Overview",
    "Puzzles",
    "Text",
    "Do's and Don'ts"
  ],
  "x-references": [
    {
      "rule": "player-start-ref",
      "from": "player.start",
      "to": "puzzles"
    }
  ],
  "x-outputKeys": [
    "PUZZLES",
    "PLAYER",
    "BALANCE",
    "TEXT"
  ],
  "x-note": "Las referencias cruzadas (x-references) dependen de datos y se validan con game-lint.js, no con este schema."
}
