{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://game-protocol/schemas/adventure.schema.json",
  "title": "GAME.md front-matter — perfil adventure",
  "type": "object",
  "required": [
    "version",
    "name",
    "profile"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "profile": {
      "const": "adventure"
    },
    "platform": {
      "type": "object"
    },
    "palettesCount": {
      "type": "integer",
      "minimum": 0
    },
    "palettes": {
      "type": "object"
    },
    "tiles": {
      "type": "object"
    },
    "tileArt": {
      "type": "object"
    },
    "entities": {
      "type": "object"
    },
    "player": {
      "type": "object"
    },
    "text": {
      "type": "object"
    },
    "win": {
      "type": "object"
    }
  },
  "additionalProperties": true,
  "x-sections": [
    "Overview",
    "Tiles",
    "Scene",
    "Entities",
    "Player",
    "Text",
    "Do's and Don'ts"
  ],
  "x-references": [],
  "x-outputKeys": [
    "PALETTES",
    "TILES",
    "TILE_ART",
    "SCENE",
    "ENTITIES",
    "PLAYER",
    "TEXT",
    "WIN"
  ],
  "x-note": "Las referencias cruzadas (x-references) dependen de datos y se validan con game-lint.js, no con este schema."
}
